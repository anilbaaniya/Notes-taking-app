# Frontend Environment Variables

# Development - Vite dev server with proxy
# Leave empty - vite.config.js proxies /api to Render backend
VITE_API_URL=

# Production on Vercel
# Leave empty - Vercel rewrites /api/* to Render backend
# VITE_API_URL=

# Alternative: If you want frontend to call Render directly (NOT recommended)
# VITE_API_URL=https://notes-taking-app-1-f1a5.onrender.com
